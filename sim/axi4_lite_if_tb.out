#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2009.vpi";
S_0x62b808f66f50 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x62b808f7d160 .scope module, "axi4_lite_if_tb" "axi4_lite_if_tb" 3 3;
 .timescale -9 -12;
v0x62b808f8de00_0 .var "clk", 0 0;
v0x62b808f8ded0_0 .var "rst_n", 0 0;
S_0x62b808f7d2f0 .scope module, "axi" "axi4_lite_if" 3 15, 4 4 0, S_0x62b808f7d160;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "ACLK";
    .port_info 1 /INPUT 1 "ARESETn";
P_0x62b808f65f10 .param/l "ADDR_WIDTH" 0 4 5, +C4<00000000000000000000000000100000>;
P_0x62b808f65f50 .param/l "DATA_WIDTH" 0 4 6, +C4<00000000000000000000000000100000>;
v0x62b808f42400_0 .net "ACLK", 0 0, v0x62b808f8de00_0;  1 drivers
v0x62b808f8dce0_0 .net "ARESETn", 0 0, v0x62b808f8ded0_0;  1 drivers
    .scope S_0x62b808f7d160;
T_0 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x62b808f8de00_0, 0, 1;
T_0.0 ;
    %delay 5000, 0;
    %load/vec4 v0x62b808f8de00_0;
    %inv;
    %store/vec4 v0x62b808f8de00_0, 0, 1;
    %jmp T_0.0;
    %end;
    .thread T_0;
    .scope S_0x62b808f7d160;
T_1 ;
    %vpi_call/w 3 21 "$display", "Interface compiled successfully." {0 0 0};
    %vpi_call/w 3 22 "$finish" {0 0 0};
    %end;
    .thread T_1;
# The file index is used to find the file name in the following table.
:file_names 5;
    "N/A";
    "<interactive>";
    "-";
    "tb/unit/axi4_lite_if_tb.sv";
    "rtl/interface/axi4_lite_if.sv";
